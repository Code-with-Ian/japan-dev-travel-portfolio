---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Experience | Dev in Japan"
  description="Developer experience, skills, and professional journey in Japan."
>
  <section class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-300">
        Experience
      </p>

      <h1 class="mt-4 text-4xl font-bold tracking-tight text-white sm:text-6xl">
        My developer journey in Japan.
      </h1>

      <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">
        This section will showcase my professional background, technical skills,
        work experience, and lessons learned while building software in Japan.
      </p>

      <div class="mt-12 grid gap-6 md:grid-cols-2">
        <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-6">
          <h2 class="text-2xl font-semibold text-white">Technical Skills</h2>
          <p class="mt-3 text-slate-400">
            Frontend development, backend systems, cloud deployment, performance,
            clean UI, and practical engineering.
          </p>
        </div>

        <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-6">
          <h2 class="text-2xl font-semibold text-white">Japan Experience</h2>
          <p class="mt-3 text-slate-400">
            Work culture, communication, teamwork, problem solving, and adapting
            as a developer in Japan.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>