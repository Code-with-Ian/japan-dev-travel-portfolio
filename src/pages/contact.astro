---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact | Dev in Japan"
  description="Contact page for collaboration, projects, and professional opportunities."
>
  <section class="px-6 py-24">
    <div class="mx-auto max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-300">
        Contact
      </p>

      <h1 class="mt-4 text-4xl font-bold tracking-tight text-white sm:text-6xl">
        Let’s connect.
      </h1>

      <p class="mt-6 text-lg leading-8 text-slate-300">
        I’m open to developer opportunities, collaborations, and conversations
        about web development, Japan, and travel.
      </p>

      <div class="mt-10 rounded-3xl border border-white/10 bg-white/[0.04] p-6">
        <p class="text-slate-300">
          Email me at:
        </p>

        <a
          href="mailto:your.email@example.com"
          class="mt-2 inline-block text-xl font-semibold text-sky-300 hover:text-sky-200"
        >
          your.email@example.com
        </a>

        <p class="mt-6 text-sm text-slate-500">
          Replace this with your real email later.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>