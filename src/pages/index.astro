---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Dev in Japan | Portfolio & Travel Stories"
  description="A portfolio showcasing developer experience in Japan, technical projects, and travel stories."
>
  <section class="relative overflow-hidden px-6 py-24 sm:py-32">
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top_left,_rgba(56,189,248,0.18),_transparent_35%),radial-gradient(circle_at_bottom_right,_rgba(168,85,247,0.16),_transparent_35%)]"></div>

    <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
      <div>
        <p class="mb-5 text-sm font-semibold uppercase tracking-[0.35em] text-sky-300">
          Japan-based Developer
        </p>

        <h1 class="max-w-4xl text-5xl font-bold tracking-tight text-white sm:text-7xl">
          Building digital products and collecting stories across Japan.
        </h1>

        <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-300">
          I’m a developer sharing my professional journey in Japan, the projects I build,
          and the places I explore along the way.
        </p>

        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
          <a
            href="/projects"
            class="rounded-full bg-sky-300 px-6 py-3 text-center text-sm font-bold text-slate-950 transition hover:bg-sky-200"
          >
            View Projects
          </a>

          <a
            href="/travel"
            class="rounded-full border border-white/15 px-6 py-3 text-center text-sm font-bold text-white transition hover:border-sky-300 hover:text-sky-300"
          >
            Explore Travels
          </a>
        </div>
      </div>

      <div class="rounded-[2rem] border border-white/10 bg-white/5 p-6 shadow-2xl shadow-sky-950/40 backdrop-blur">
        <div class="rounded-[1.5rem] bg-slate-900 p-6">
          <p class="text-sm uppercase tracking-[0.3em] text-slate-400">
            Current Focus
          </p>

          <div class="mt-6 space-y-5">
            <div>
              <h2 class="text-xl font-semibold text-white">Developer Experience</h2>
              <p class="mt-2 text-slate-400">
                Web development, clean UI, performance, and practical engineering.
              </p>
            </div>

            <div>
              <h2 class="text-xl font-semibold text-white">Life in Japan</h2>
              <p class="mt-2 text-slate-400">
                Lessons, culture, routines, and professional growth while living in Japan.
              </p>
            </div>

            <div>
              <h2 class="text-xl font-semibold text-white">Travel Stories</h2>
              <p class="mt-2 text-slate-400">
                Photos, notes, guides, and memories from cities and hidden corners.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="px-6 py-20">
    <div class="mx-auto max-w-6xl">
      <div class="mb-10">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-300">
          Portfolio Sections
        </p>
        <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">
          What this site will showcase
        </h2>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        <a href="/experience" class="rounded-3xl border border-white/10 bg-white/[0.04] p-6 transition hover:-translate-y-1 hover:border-sky-300/50">
          <h3 class="text-xl font-semibold text-white">Experience in Japan</h3>
          <p class="mt-3 text-slate-400">
            Your developer journey, skills, work style, and lessons from working in Japan.
          </p>
        </a>

        <a href="/projects" class="rounded-3xl border border-white/10 bg-white/[0.04] p-6 transition hover:-translate-y-1 hover:border-sky-300/50">
          <h3 class="text-xl font-semibold text-white">Projects</h3>
          <p class="mt-3 text-slate-400">
            Selected apps, websites, tools, and case studies with technical details.
          </p>
        </a>

        <a href="/travel" class="rounded-3xl border border-white/10 bg-white/[0.04] p-6 transition hover:-translate-y-1 hover:border-sky-300/50">
          <h3 class="text-xl font-semibold text-white">Travel</h3>
          <p class="mt-3 text-slate-400">
            Travel stories, photos, local notes, and memorable places around Japan and beyond.
          </p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>