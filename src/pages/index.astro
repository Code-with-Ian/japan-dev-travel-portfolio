---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import TravelCard from "../components/TravelCard.astro";
import OkinawaVibes from "../components/OkinawaVibes.astro";
import { site } from "../data/site";

type ProjectEntry = CollectionEntry<"projects">;
type TravelEntry = CollectionEntry<"travel">;

type Stat = {
  value: string;
  label: string;
};

type FocusArea = {
  title: string;
  description: string;
};

const projects = (await getCollection("projects")) as ProjectEntry[];
const travelEntries = (await getCollection("travel")) as TravelEntry[];

const sortedProjects = [...projects].sort(
  (a: ProjectEntry, b: ProjectEntry) =>
    b.data.date.getTime() - a.data.date.getTime()
);

const sortedTravelEntries = [...travelEntries].sort(
  (a: TravelEntry, b: TravelEntry) =>
    b.data.date.getTime() - a.data.date.getTime()
);

const featuredProjects =
  sortedProjects.filter((project: ProjectEntry) => project.data.featured).length > 0
    ? sortedProjects
        .filter((project: ProjectEntry) => project.data.featured)
        .slice(0, 3)
    : sortedProjects.slice(0, 3);

const featuredTravelEntries = sortedTravelEntries.slice(0, 3);

const stats: Stat[] = [
  {
    value: "Japan",
    label: "Current base",
  },
  {
    value: "Web",
    label: "Main development focus",
  },
  {
    value: "AWS",
    label: "Deployment platform",
  },
];

const focusAreas: FocusArea[] = [
  {
    title: "Developer Experience",
    description:
      "Projects, technical decisions, lessons learned, and practical software engineering notes.",
  },
  {
    title: "Life in Japan",
    description:
      "Professional growth, work culture, daily routines, and observations from living in Japan.",
  },
  {
    title: "Travel Stories",
    description:
      "Places, photos, memories, and small discoveries from Japan and beyond.",
  },
];
---

<BaseLayout title={site.seoTitle} description={site.seoDescription}>
  <section class="relative overflow-hidden px-6 py-24 sm:py-32">
    <OkinawaVibes />

    <div class="absolute inset-0 -z-20 bg-[radial-gradient(circle_at_top_left,_rgba(56,189,248,0.18),_transparent_35%),radial-gradient(circle_at_bottom_right,_rgba(168,85,247,0.16),_transparent_35%)]"></div>

    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-cyan-400/5 via-transparent to-emerald-300/5"></div>

    <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
      <div>
        <p class="mb-5 text-sm font-semibold uppercase tracking-[0.35em] text-sky-300">
          {site.location}-based {site.role}
        </p>

        <h1 class="max-w-4xl text-5xl font-bold tracking-tight text-white sm:text-7xl">
          Building digital products and collecting stories across Japan.
        </h1>

        <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-300">
          {site.intro}
        </p>

        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
          <a
            href="/projects"
            class="rounded-full bg-sky-300 px-6 py-3 text-center text-sm font-bold text-slate-950 transition hover:bg-sky-200"
          >
            View Projects
          </a>

          <a
            href="/travel"
            class="rounded-full border border-white/15 px-6 py-3 text-center text-sm font-bold text-white transition hover:border-sky-300 hover:text-sky-300"
          >
            Explore Travels
          </a>
        </div>
      </div>

      <div class="rounded-[2rem] border border-white/10 bg-white/5 p-6 shadow-2xl shadow-sky-950/40 backdrop-blur">
        <div class="rounded-[1.5rem] bg-slate-900/90 p-6">
          <p class="text-sm uppercase tracking-[0.3em] text-slate-400">
            Current Focus
          </p>

          <div class="mt-6 space-y-5">
            {
              focusAreas.map((area: FocusArea) => (
                <div>
                  <h2 class="text-xl font-semibold text-white">{area.title}</h2>
                  <p class="mt-2 text-slate-400">{area.description}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="px-6 pb-20">
    <div class="mx-auto grid max-w-6xl gap-4 sm:grid-cols-3">
      {
        stats.map((stat: Stat) => (
          <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-6">
            <p class="text-3xl font-bold text-white">{stat.value}</p>
            <p class="mt-2 text-sm text-slate-400">{stat.label}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="px-6 py-20">
    <div class="mx-auto max-w-6xl">
      <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-300">
            Featured Work
          </p>
          <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">
            Selected projects
          </h2>
        </div>

        <a href="/projects" class="text-sm font-semibold text-sky-300 hover:text-sky-200">
          View all projects →
        </a>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {
          featuredProjects.map((project: ProjectEntry) => (
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              tags={project.data.tags}
              href={`/projects/${project.id}`}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="px-6 py-20">
    <div class="mx-auto max-w-6xl">
      <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-300">
            Travel Journal
          </p>
          <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">
            Recent stories
          </h2>
        </div>

        <a href="/travel" class="text-sm font-semibold text-sky-300 hover:text-sky-200">
          View all travel stories →
        </a>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {
          featuredTravelEntries.map((entry: TravelEntry) => (
            <TravelCard
              title={entry.data.title}
              place={entry.data.place}
              description={entry.data.description}
              tags={entry.data.tags}
              href={`/travel/${entry.id}`}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="px-6 py-20">
    <div class="mx-auto max-w-6xl rounded-[2rem] border border-white/10 bg-white/[0.04] p-8 md:p-12">
      <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-300">
            Let’s Connect
          </p>

          <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">
            Want to collaborate or talk about development in Japan?
          </h2>

          <p class="mt-4 max-w-2xl text-slate-300">
            I’m open to developer opportunities, collaborations, and conversations
            about web development, Japan life, and travel.
          </p>
        </div>

        <a
          href="/contact"
          class="rounded-full bg-sky-300 px-6 py-3 text-center text-sm font-bold text-slate-950 transition hover:bg-sky-200"
        >
          Contact Me
        </a>
      </div>
    </div>
  </section>
</BaseLayout>