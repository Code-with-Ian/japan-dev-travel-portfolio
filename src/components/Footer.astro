---
import { site } from "../data/site";
import type { SocialLink } from "../data/site";
---

<footer class="border-t border-white/10 px-6 py-10">
  <div class="mx-auto flex max-w-6xl flex-col gap-4 text-sm text-slate-400 md:flex-row md:items-center md:justify-between">
    <p>
      © {new Date().getFullYear()} {site.name}.
      <span data-i18n="footer.built">Built with Astro and deployed on AWS Amplify.</span>
    </p>

    <div class="flex gap-4">
      {
        site.socialLinks.map((link: SocialLink) => (
          <a href={link.href} class="hover:text-sky-300" target="_blank" rel="noreferrer">
            {link.label}
          </a>
        ))
      }

      <a href="/contact" data-i18n="footer.contact" class="hover:text-sky-300">
        Contact
      </a>
    </div>
  </div>
</footer>