---
import { site } from "../data/site";
import SiteControls from "./SiteControls.astro";

type NavItem = {
  href: string;
  label: string;
  key: string;
};

const navItems: NavItem[] = [
  { href: "/", label: "Home", key: "nav.home" },
  { href: "/experience", label: "Experience", key: "nav.experience" },
  { href: "/projects", label: "Projects", key: "nav.projects" },
  { href: "/travel", label: "Travel", key: "nav.travel" },
  { href: "/contact", label: "Contact", key: "nav.contact" },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-slate-950/80 backdrop-blur">
  <nav class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-4">
    <a href="/" class="text-sm font-bold uppercase tracking-[0.25em] text-sky-300">
      {site.brand}
    </a>

    <div class="hidden items-center gap-6 lg:flex">
      {
        navItems.map((item: NavItem) => {
          const isActive =
            item.href === "/"
              ? currentPath === "/"
              : currentPath.startsWith(item.href);

          return (
            <a
              href={item.href}
              data-i18n={item.key}
              class:list={[
                "text-sm transition hover:text-sky-300",
                isActive ? "text-sky-300" : "text-slate-300",
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
    </div>

    <div class="flex items-center gap-3">
      <a
        href="/contact"
        data-i18n="nav.connect"
        class="hidden rounded-full border border-sky-400/40 px-4 py-2 text-sm font-medium text-sky-200 transition hover:border-sky-300 hover:bg-sky-400/10 sm:inline-flex"
      >
        Let’s connect
      </a>

      <SiteControls />
    </div>
  </nav>
</header>