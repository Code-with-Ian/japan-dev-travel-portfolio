---
interface Props {
  title: string;
  place: string;
  description: string;
  href: string;
  i18nBaseKey: string;
  tags?: string[];
}

const { title, place, description, href, i18nBaseKey, tags = [] } = Astro.props;
---

<a
  href={href}
  class="group block rounded-3xl border border-white/10 bg-white/[0.04] p-6 transition duration-300 hover:-translate-y-2 hover:border-sky-300/60 hover:bg-white/[0.07] hover:shadow-2xl hover:shadow-sky-950/30"
>
  <div class="mb-5 h-48 rounded-2xl bg-gradient-to-br from-sky-400/20 to-purple-500/20"></div>

  <p
    class="text-sm font-semibold uppercase tracking-[0.25em] text-sky-300"
    data-i18n={`${i18nBaseKey}.place`}
  >
    {place}
  </p>

  <h2 class="mt-3 text-2xl font-semibold text-white" data-i18n={`${i18nBaseKey}.title`}>
    {title}
  </h2>

  <p class="mt-3 text-slate-400" data-i18n={`${i18nBaseKey}.description`}>
    {description}
  </p>

  {
    tags.length > 0 && (
      <div class="mt-6 flex flex-wrap gap-2">
        {tags.map((tag: string, index: number) => (
          <span
            data-i18n={`${i18nBaseKey}.tags.${index}`}
            class="rounded-full border border-sky-300/20 bg-sky-300/10 px-3 py-1 text-xs font-medium text-sky-200"
          >
            {tag}
          </span>
        ))}
      </div>
    )
  }

  <p class="mt-6 text-sm font-semibold text-sky-300" data-i18n="travel.readStory">
    Read story →
  </p>
</a>